SECRET_KEY=your-very-secret-key-change-this

# Database (set DATABASE_URL for PostgreSQL in production)
DATABASE_URL=
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=salon_db

# Admin seed credentials (used only on first DB init)
SEED_ADMIN_NAME=Admin
SEED_ADMIN_USERNAME=your_admin_username
SEED_ADMIN_PASSWORD=your_admin_password
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PHONE=0000000000

# SMS — Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM=+1234567890
ADMIN_PHONE=+919999999999

# Email — Resend
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=New Shades <noreply@yourdomain.com>

# Session
SESSION_COOKIE_SECURE=false

# CORS
CORS_ORIGINS=http://localhost:5000
